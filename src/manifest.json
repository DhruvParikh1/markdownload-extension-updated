{
  "manifest_version": 3,
  "name": "__MSG_manifest_name__",
  "version": "4.4.0",
  "author": "Dhruv Parikh",
  "description": "__MSG_manifest_description__",
  "default_locale": "en",
  "icons": {
    "16": "icons/favicon-16x16.png",
    "32": "icons/favicon-32x32.png",
    "48": "icons/favicon-48x48.png",
    "128": "icons/appicon-128x128.png",
    "192": "icons/favicon-192x192.png",
    "512": "icons/favicon-512x512.png"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "contextMenus",
    "clipboardWrite",
    "scripting",
    "offscreen"
  ],
  "optional_permissions": [
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "__MSG_manifest_action_title__",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/favicon-16x16.png",
      "32": "icons/favicon-32x32.png",
      "48": "icons/favicon-48x48.png",
      "128": "icons/appicon-128x128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "options_ui": {
    "page": "options/options.html",
    "browser_style": false,
    "open_in_tab": true
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+M"
      }
    },
    "download_tab_as_markdown": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "__MSG_manifest_command_download_tab_as_markdown__"
    },
    "copy_tab_as_markdown": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "__MSG_manifest_command_copy_tab_as_markdown__"
    },
    "copy_selection_as_markdown": {
      "description": "__MSG_manifest_command_copy_selection_as_markdown__"
    },
    "copy_tab_as_markdown_link": {
      "suggested_key": {
        "default": "Alt+Shift+L"
      },
      "description": "__MSG_manifest_command_copy_tab_as_markdown_link__"
    },
    "copy_selected_tab_as_markdown_link": {
      "description": "__MSG_manifest_command_copy_selected_tab_as_markdown_link__"
    },
    "copy_selection_to_obsidian": {
      "description": "__MSG_manifest_command_copy_selection_to_obsidian__"
    },
    "copy_tab_to_obsidian": {
      "description": "__MSG_manifest_command_copy_tab_to_obsidian__"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["contentScript/pageContext.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "marksnip@dhruvparikh",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
